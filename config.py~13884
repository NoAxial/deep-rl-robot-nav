# ======================================================================
# Helpers
# ======================================================================
def _deep_merge(base: dict, override: dict) -> dict:
    """Recursively merge *override* into *base* (non-destructive)."""
    result = copy.deepcopy(base)
    for key, value in override.items():
        if key in result and isinstance(result[key], dict) and isinstance(value, dict):
            result[key] = _deep_merge(result[key], value)
        else:
            result[key] = copy.deepcopy(value)
    return result


def _apply_legacy_robot_config(user: dict[str, Any], config: dict[str, Any]) -> None:
    """Translate the old per-step motion settings into velocity limits."""
    robot_override = user.get("robot", {})
    if not isinstance(robot_override, dict):
        return

    dt = float(config["physics"]["dt"])
    if "step_size" in robot_override and "max_linear_speed" not in robot_override:
        config["robot"]["max_linear_speed"] = float(robot_override["step_size"]) / dt
    if "turn_angle" in robot_override and "max_angular_speed" not in robot_override:
        config["robot"]["max_angular_speed"] = math.radians(
            float(robot_override["turn_angle"])
        ) / dt


def _validate_config(config: dict[str, Any]) -> None:
    """Fail early for values that would otherwise break an episode or model."""
    world = config["world"]
    robot = config["robot"]
    physics = config["physics"]
    training = config["training"]

    if int(world["width"]) <= 200 or int(world["height"]) <= 120:
        raise ValueError("world width must be > 200 and height must be > 120")
    if int(world["num_obstacles_min"]) < 0:
        raise ValueError("num_obstacles_min must be non-negative")
    if int(world["num_obstacles_min"]) > int(world["num_obstacles_max"]):
        raise ValueError("num_obstacles_min cannot exceed num_obstacles_max")
    if int(robot["num_sensors"]) < 1:
        raise ValueError("robot.num_sensors must be at least 1")

    positive_values = {
        "robot.radius": robot["radius"],
        "robot.sensor_range": robot["sensor_range"],
        "robot.max_linear_speed": robot["max_linear_speed"],
        "robot.max_angular_speed": robot["max_angular_speed"],
        "physics.mass": physics["mass"],
        "physics.inertia": physics["inertia"],
        "physics.track_width": physics["track_width"],
        "physics.wheel_radius": physics["wheel_radius"],
        "physics.motor_torque_max": physics["motor_torque_max"],
        "physics.dt": physics["dt"],
        "physics.physics_substeps": physics["physics_substeps"],
        "episode.max_steps": config["episode"]["max_steps"],
        "training.n_envs": training["n_envs"],
    }
    for name, value in positive_values.items():
        if float(value) <= 0:
            raise ValueError(f"{name} must be positive")

    if str(training["algorithm"]).upper() != "SAC":
        raise ValueError(
            "training.algorithm must be 'SAC'; use the compare command for PPO"
        )


def load_config(path: str | Path | None = None) -> dict[str, Any]:
    """Load and return a fully populated config dict.

    Parameters
    ----------
    path : str or Path, optional
        Path to a user YAML file.  Any keys present override defaults;
        missing keys are filled from ``DEFAULT_CONFIG``.
        If *None* or the file does not exist, pure defaults are returned.
    """
    config = copy.deepcopy(DEFAULT_CONFIG)
    if path is not None:
        p = Path(path)
        if not p.is_file():
            raise FileNotFoundError(f"Configuration file not found: {p}")
        with open(p, "r", encoding="utf-8") as fh:
            user = yaml.safe_load(fh) or {}
        if not isinstance(user, dict):
            raise ValueError(f"Configuration root must be a mapping: {p}")
        config = _deep_merge(config, user)
        _apply_legacy_robot_config(user, config)
        print(f"[config] Loaded: {p}")
    else:
        print("[config] Using default configuration")
    _validate_config(config)
    return config
